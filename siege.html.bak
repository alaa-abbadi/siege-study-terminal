<!DOCTYPE html>
<!--
================================================================================
 SIEGE // Study Terminal for IGCSE
 Version 1.0.0
 © 2026 — Single-user commercial license
 No resale, no redistribution.
 Built for students who hate studying but need to grind.
================================================================================
-->
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#050505">
<meta name="description" content="SIEGE — AI-powered IGCSE study terminal. Real past papers, no hallucinated questions.">
<title>SIEGE // study terminal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;0,800;1,400&family=Major+Mono+Display&family=VT323&family=Noto+Naskh+Arabic:wght@400;700&display=swap" rel="stylesheet">
<style>
/* ============================================================
   THEMES — pure black brutalist · 3 variants
   ============================================================ */
:root,
[data-theme="red"]{
  --bg:#050505;
  --bg-2:#0c0c0c;
  --bg-3:#141414;
  --ink:#f2f2f2;
  --ink-dim:#bcbcbc;
  --muted:#666;
  --dim:#3a3a3a;
  --line:#1f1f1f;
  --accent:#ff0033;
  --accent-dim:#7a0019;
  --accent-rgb:255,0,51;
  --sec:#00ffe0;
  --sec-dim:#005c52;
  --warn:#ffcc00;
  --ok:#00ff88;
  --bad:#ff0033;
  --chem:#ff0033;
  --bio:#00ff88;
  --phys:#00ffe0;
  --math:#ffcc00;
  --eng:#ff66cc;
  --ar:#ff8800;
  --hum:#9966ff;
  --biz:#66ccff;
  --comp:#ccff00;
  --lit:#ff5577;
}
[data-theme="green"]{
  --bg:#020a04;
  --bg-2:#031408;
  --bg-3:#04200d;
  --ink:#d4ffe1;
  --ink-dim:#7fd99c;
  --muted:#3a6047;
  --dim:#1f3527;
  --line:#0e1c14;
  --accent:#00ff41;
  --accent-dim:#006619;
  --accent-rgb:0,255,65;
  --sec:#80ff80;
  --sec-dim:#205520;
  --warn:#ffd700;
  --ok:#80ff80;
  --bad:#ff4040;
}
[data-theme="mono"]{
  --bg:#000;
  --bg-2:#0a0a0a;
  --bg-3:#161616;
  --ink:#ffffff;
  --ink-dim:#bbbbbb;
  --muted:#777;
  --dim:#404040;
  --line:#222;
  --accent:#ffffff;
  --accent-dim:#999;
  --accent-rgb:255,255,255;
  --sec:#aaaaaa;
  --sec-dim:#555;
  --warn:#ffffff;
  --ok:#ffffff;
  --bad:#ffffff;
}

:root{
  --mono:'JetBrains Mono',ui-monospace,monospace;
  --display:'Major Mono Display',monospace;
  --term:'VT323',monospace;
  --ar-font:'Noto Naskh Arabic',serif;
  --tx:0.12s ease;
}

/* ============================================================
   RESET + BASE
   ============================================================ */
*{box-sizing:border-box;margin:0;padding:0}
*::selection{background:var(--accent);color:var(--bg)}
html,body{
  background:var(--bg);color:var(--ink);
  font-family:var(--mono);font-size:13px;line-height:1.5;
  min-height:100vh;overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
[dir="rtl"] body{font-family:var(--ar-font),var(--mono)}
body{
  background-image:
    linear-gradient(var(--line) 1px,transparent 1px),
    linear-gradient(90deg,var(--line) 1px,transparent 1px);
  background-size:40px 40px;background-position:-1px -1px;
}
body::before{
  content:"";position:fixed;inset:0;pointer-events:none;z-index:1;
  background:repeating-linear-gradient(0deg,rgba(255,255,255,0.012) 0,rgba(255,255,255,0.012) 1px,transparent 1px,transparent 3px);
}
body::after{
  content:"";position:fixed;inset:0;pointer-events:none;z-index:2;
  background:radial-gradient(ellipse at top,transparent 0%,rgba(0,0,0,0.5) 100%);
}
a{color:var(--sec);text-decoration:none}
a:hover{color:var(--accent)}
::-webkit-scrollbar{width:8px;height:8px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--dim)}
::-webkit-scrollbar-thumb:hover{background:var(--muted)}

/* ============================================================
   APP SHELL
   ============================================================ */
.app{position:relative;z-index:3;display:grid;grid-template-columns:240px 1fr;min-height:100vh}
@media(max-width:900px){.app{grid-template-columns:1fr}}

/* ============================================================
   SIDEBAR
   ============================================================ */
.sidebar{
  border-right:2px solid var(--ink);background:var(--bg);
  padding:20px 0;position:sticky;top:0;height:100vh;overflow-y:auto;
  display:flex;flex-direction:column;
}
@media(max-width:900px){
  .sidebar{position:fixed;left:-260px;width:240px;transition:left 0.2s;z-index:90;border-right:2px solid var(--accent)}
  .sidebar.open{left:0}
  .sidebar-backdrop{position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:80;display:none}
  .sidebar-backdrop.show{display:block}
}
.sb-brand{padding:0 20px 24px;border-bottom:2px solid var(--line);margin-bottom:16px;display:flex;align-items:center;gap:10px}
.sb-mark{
  width:32px;height:32px;background:var(--accent);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--display);font-size:14px;color:var(--bg);
  border:2px solid var(--ink);flex-shrink:0;
}
.sb-name{font-family:var(--display);font-size:14px;letter-spacing:2px;line-height:1}
.sb-sub{font-size:9px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:3px}

.sb-profile{padding:12px 20px;border-bottom:2px solid var(--line);margin-bottom:8px;cursor:pointer;display:flex;align-items:center;gap:10px;transition:all var(--tx)}
.sb-profile:hover{background:var(--bg-2)}
.sb-avatar{
  width:28px;height:28px;background:var(--bg-3);border:2px solid var(--ink);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--display);font-size:12px;flex-shrink:0;
}
.sb-pn{flex:1;overflow:hidden}
.sb-pn-name{font-size:11px;color:var(--ink);text-transform:lowercase;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sb-pn-meta{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:2px}
.sb-pn-icon{color:var(--muted);font-size:14px}

.sb-nav{flex:1;padding:8px 0;display:flex;flex-direction:column;gap:1px}
.sb-item{
  display:flex;align-items:center;gap:12px;padding:10px 20px;
  background:transparent;border:none;border-left:3px solid transparent;
  color:var(--muted);font-family:var(--mono);font-size:11px;
  letter-spacing:1.5px;text-transform:uppercase;font-weight:700;
  cursor:pointer;text-align:left;width:100%;transition:all var(--tx);
}
.sb-item:hover{color:var(--ink);background:var(--bg-2)}
.sb-item.active{color:var(--accent);background:var(--bg-2);border-left-color:var(--accent)}
.sb-icon{width:14px;font-family:var(--term);font-size:14px;flex-shrink:0;color:inherit}
.sb-foot{padding:16px 20px;border-top:2px solid var(--line);font-size:9px;color:var(--muted);letter-spacing:1px;text-transform:uppercase}
.sb-foot .row{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.sb-foot .row:last-child{margin-bottom:0}
.sb-foot b{color:var(--ink-dim);font-weight:700}
.sb-foot .dot{display:inline-block;width:5px;height:5px;background:var(--ok);border-radius:50%;margin-right:5px;animation:pulse 1.6s ease infinite}
.sb-foot .dot.off{background:var(--muted);animation:none}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}

/* mobile nav button */
.mobile-nav-btn{display:none;position:fixed;top:14px;left:14px;z-index:95;background:var(--accent);border:2px solid var(--ink);color:var(--bg);font-family:var(--display);font-size:14px;width:42px;height:42px;align-items:center;justify-content:center;cursor:pointer}
@media(max-width:900px){.mobile-nav-btn{display:flex}}

/* ============================================================
   MAIN AREA
   ============================================================ */
.main{padding:32px 32px 80px;overflow-x:hidden;max-width:100%}
@media(max-width:900px){.main{padding:72px 16px 60px}}

.section{display:none;animation:fadeIn 0.25s ease}
.section.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

.section-head{display:flex;justify-content:space-between;align-items:end;margin-bottom:24px;padding-bottom:14px;border-bottom:2px solid var(--ink);gap:16px;flex-wrap:wrap}
.section-head h2{font-family:var(--display);font-size:clamp(22px,4vw,34px);text-transform:lowercase;letter-spacing:1px;line-height:1}
.section-head .meta{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:2px}

/* ============================================================
   CARDS / GRIDS
   ============================================================ */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:16px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:16px}
.grid-5{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:16px}
@media(max-width:1100px){.grid-4,.grid-5{grid-template-columns:repeat(2,1fr)}}
@media(max-width:720px){.grid-2,.grid-3,.grid-4,.grid-5{grid-template-columns:1fr}}

.card{
  border:2px solid var(--ink);background:var(--bg-2);padding:20px;position:relative;
}
.card.flush{padding:0}
.card.flush .card-tag{top:-11px}
.card.flush .card-body{padding:20px}
.card-tag{position:absolute;top:-11px;left:16px;background:var(--bg);padding:0 8px;font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;font-weight:700}
.card-tag.hot{color:var(--accent)}
.card-tag.cy{color:var(--sec)}
.card-tag.warn{color:var(--warn)}
.card-tag.ok{color:var(--ok)}
.card h3{font-family:var(--display);font-size:16px;text-transform:lowercase;margin-bottom:10px;letter-spacing:1px}
.card p{font-size:12px;color:var(--ink-dim);margin-bottom:8px}
.card p:last-child{margin-bottom:0}

/* ============================================================
   HERO
   ============================================================ */
.hero{
  border:2px solid var(--ink);padding:28px;margin-bottom:24px;position:relative;
  background:linear-gradient(135deg,rgba(var(--accent-rgb),0.04) 0%,transparent 60%);
}
.hero::before{content:"[ TODAY ]";position:absolute;top:-11px;left:24px;background:var(--bg);padding:0 10px;font-size:10px;letter-spacing:3px;color:var(--accent);font-weight:700}
.hero h1{font-family:var(--display);font-size:clamp(26px,4.5vw,46px);line-height:1;text-transform:lowercase;margin-bottom:10px}
.hero-meta{display:flex;gap:20px;flex-wrap:wrap;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:18px}
.hero-meta span b{color:var(--ink);font-weight:700}
.hero-meta span.acc b{color:var(--accent)}

/* ============================================================
   BUTTONS
   ============================================================ */
.btn{
  background:var(--ink);color:var(--bg);border:2px solid var(--ink);
  padding:10px 18px;font-family:var(--mono);font-size:11px;font-weight:700;
  letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all var(--tx);
  display:inline-flex;align-items:center;gap:8px;line-height:1;
}
.btn:hover{background:var(--accent);border-color:var(--accent);color:var(--bg)}
.btn:disabled{background:var(--dim);border-color:var(--dim);color:var(--muted);cursor:not-allowed}
.btn.ghost{background:transparent;color:var(--ink)}
.btn.ghost:hover{background:var(--ink);color:var(--bg)}
.btn.hot{background:var(--accent);border-color:var(--accent);color:var(--bg)}
.btn.hot:hover{background:var(--ink);border-color:var(--ink);color:var(--bg)}
.btn.cy{background:var(--sec);border-color:var(--sec);color:var(--bg)}
.btn.warn{background:var(--warn);border-color:var(--warn);color:var(--bg)}
.btn.sm{padding:6px 10px;font-size:10px;letter-spacing:1.5px}
.btn.xs{padding:4px 8px;font-size:9px;letter-spacing:1px}
.btn.danger{color:var(--bad);border-color:var(--bad);background:transparent}
.btn.danger:hover{background:var(--bad);color:var(--bg)}
.btn.full{width:100%;justify-content:center}
.btn-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}

/* ============================================================
   FORM
   ============================================================ */
.field{margin-bottom:16px}
.field label{display:block;font-size:10px;text-transform:uppercase;letter-spacing:2px;color:var(--muted);margin-bottom:6px;font-weight:700}
.field input,.field select,.field textarea{
  width:100%;background:var(--bg);border:2px solid var(--dim);padding:10px 12px;
  color:var(--ink);font-family:var(--mono);font-size:13px;outline:none;transition:border-color var(--tx);
}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--accent)}
.field textarea{min-height:80px;resize:vertical;font-family:var(--mono)}
.field-hint{font-size:10px;color:var(--muted);margin-top:4px}
.field-hint a{color:var(--sec)}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:600px){.field-row{grid-template-columns:1fr}}

/* checkbox-style toggles */
.chk{display:inline-flex;align-items:center;gap:8px;cursor:pointer;padding:6px 10px;border:1px solid var(--dim);background:var(--bg);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:1px;transition:all var(--tx)}
.chk:hover{border-color:var(--ink);color:var(--ink)}
.chk.on{border-color:var(--accent);color:var(--accent);background:rgba(var(--accent-rgb),0.06)}
.chk input{display:none}

/* segmented */
.seg{display:flex;border:2px solid var(--ink)}
.seg button{flex:1;padding:8px;background:var(--bg);border:none;color:var(--muted);font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;border-right:2px solid var(--ink);transition:all var(--tx)}
.seg button:last-child{border-right:none}
.seg button:hover{color:var(--ink)}
.seg button.on{background:var(--ink);color:var(--bg)}

/* ============================================================
   STATS
   ============================================================ */
.stat-big{font-family:var(--term);font-size:54px;line-height:1;color:var(--ink)}
.stat-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:2px;margin-top:4px}
.stat-sub{font-size:11px;color:var(--ink-dim);margin-top:6px}

/* progress bars */
.subj-row{display:flex;align-items:center;gap:14px;padding:12px 0;border-top:1px solid var(--line)}
.subj-row:first-child{border-top:none}
.subj-tag{width:90px;font-family:var(--display);font-size:12px;text-transform:lowercase;letter-spacing:1px;color:var(--ink)}
.subj-bar-wrap{flex:1;height:14px;background:var(--bg);border:1px solid var(--dim);position:relative;overflow:hidden}
.subj-bar{height:100%;background:var(--ink);transition:width 0.4s;background:repeating-linear-gradient(45deg,var(--accent) 0,var(--accent) 6px,var(--accent-dim) 6px,var(--accent-dim) 12px)}
.subj-pct{font-family:var(--term);font-size:20px;width:54px;text-align:right;color:var(--ink)}

/* ============================================================
   MISSION
   ============================================================ */
.mission-list{margin-top:14px}
.mission-item{
  display:flex;align-items:flex-start;gap:14px;padding:14px;border:1px solid var(--line);
  margin-bottom:8px;background:var(--bg);transition:all var(--tx);cursor:pointer;
}
.mission-item:hover{border-color:var(--ink)}
.mission-item.done{opacity:0.4}
.mission-item.done .mission-task{text-decoration:line-through}
.mission-check{
  width:22px;height:22px;border:2px solid var(--ink);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--bg);
}
.mission-item.done .mission-check{background:var(--ok);color:var(--bg)}
.mission-item.done .mission-check::after{content:"✕"}
.mission-body{flex:1}
.mission-task{font-size:13px;font-weight:500;color:var(--ink);line-height:1.5}
.mission-meta{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1.5px;margin-top:6px;display:flex;gap:8px;flex-wrap:wrap}
.pill{padding:2px 7px;border:1px solid var(--dim);color:var(--muted);font-size:9px;letter-spacing:1.5px;text-transform:uppercase;font-weight:700}
.pill.hot{color:var(--accent);border-color:var(--accent);background:rgba(var(--accent-rgb),0.06)}
.pill.cy{color:var(--sec);border-color:var(--sec);background:rgba(0,255,224,0.06)}
.pill.warn{color:var(--warn);border-color:var(--warn);background:rgba(255,204,0,0.06)}
.pill.ok{color:var(--ok);border-color:var(--ok)}
.pill.subj{color:var(--ink);border-color:var(--ink)}
.mission-act{display:flex;gap:6px;align-items:center}

/* paper link inside mission */
.mission-task a.pcode{color:var(--accent);border-bottom:1px dashed var(--accent);padding:0 2px}
.mission-task a.pcode:hover{background:var(--accent);color:var(--bg)}

/* ============================================================
   TOPIC LIST
   ============================================================ */
.topic-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:8px;margin-top:16px}
.topic{
  padding:12px;border:1px solid var(--line);background:var(--bg);cursor:pointer;
  display:flex;align-items:center;gap:10px;transition:all var(--tx);
}
.topic:hover{border-color:var(--ink);background:var(--bg-2)}
.topic-status{
  width:18px;height:18px;border:2px solid var(--dim);flex-shrink:0;font-family:var(--term);font-size:14px;
  display:flex;align-items:center;justify-content:center;
}
.topic.s-1 .topic-status{background:var(--warn);border-color:var(--warn);color:var(--bg)}
.topic.s-1 .topic-status::after{content:"~"}
.topic.s-2 .topic-status{background:var(--ok);border-color:var(--ok);color:var(--bg)}
.topic.s-2 .topic-status::after{content:"✓"}
.topic-name{font-size:12px;color:var(--ink);flex:1}
.topic.s-0 .topic-name{color:var(--muted)}
.topic-num{font-family:var(--term);font-size:14px;color:var(--muted);margin-right:4px}
.topic-act{font-size:10px;color:var(--muted);padding:2px 6px;border:1px solid var(--dim);text-transform:uppercase;letter-spacing:1px}
.topic-act:hover{color:var(--accent);border-color:var(--accent)}

/* ============================================================
   PAPERS
   ============================================================ */
.paper-filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;align-items:center}
.paper-filters select,.paper-filters input{background:var(--bg);border:1px solid var(--dim);color:var(--ink);padding:6px 8px;font-family:var(--mono);font-size:11px}
.paper-filters .filt-lbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:1.5px;margin-right:4px}

.paper-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:8px}
.paper-cell{
  padding:10px;border:1px solid var(--line);background:var(--bg);cursor:pointer;
  font-size:11px;transition:all var(--tx);position:relative;
}
.paper-cell:hover{border-color:var(--ink);background:var(--bg-2)}
.paper-code{font-family:var(--term);font-size:18px;color:var(--ink);line-height:1}
.paper-meta{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:4px}
.paper-cell.attempted{border-color:var(--warn)}
.paper-cell.done{border-color:var(--ok)}
.paper-cell.done .paper-code{color:var(--ok)}
.paper-score{position:absolute;top:6px;right:8px;font-family:var(--term);font-size:14px;color:var(--ok)}
.paper-links{display:flex;gap:4px;margin-top:6px}
.paper-links a{font-size:9px;text-transform:uppercase;letter-spacing:1px;padding:1px 5px;border:1px solid var(--dim);color:var(--muted)}
.paper-links a:hover{border-color:var(--accent);color:var(--accent)}

/* ============================================================
   CHAT / AI
   ============================================================ */
.ai-modes{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px;margin-bottom:20px}
.mode-card{
  padding:14px;border:2px solid var(--line);background:var(--bg-2);cursor:pointer;
  transition:all var(--tx);position:relative;
}
.mode-card:hover{border-color:var(--ink)}
.mode-card.active{border-color:var(--accent);background:rgba(var(--accent-rgb),0.06)}
.mode-card.active::before{content:"";position:absolute;top:0;left:0;width:100%;height:3px;background:var(--accent)}
.mode-icon{font-family:var(--term);font-size:22px;color:var(--accent);margin-bottom:6px}
.mode-name{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--ink);margin-bottom:4px}
.mode-desc{font-size:10px;color:var(--muted);line-height:1.4}

.chat-box{
  border:2px solid var(--ink);background:var(--bg-2);
  display:flex;flex-direction:column;height:560px;
}
.chat-head{padding:12px 16px;border-bottom:2px solid var(--ink);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
.chat-head-title{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--accent);font-weight:700}
.chat-head-status{font-size:10px;color:var(--muted);display:flex;align-items:center;gap:6px;text-transform:uppercase;letter-spacing:1.5px}
.chat-head-status .dot{width:6px;height:6px;background:var(--ok);border-radius:50%;animation:pulse 1.4s ease infinite}
.chat-head-status.off .dot{background:var(--muted);animation:none}
.chat-log{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:14px}
.chat-msg{font-size:13px;line-height:1.6;padding-left:16px;border-left:2px solid var(--sec)}
.chat-msg.user::before{content:"YOU // ";font-size:9px;letter-spacing:2px;color:var(--sec);text-transform:uppercase;display:block;margin-bottom:4px;font-weight:700}
.chat-msg.ai{border-left-color:var(--accent)}
.chat-msg.ai::before{content:"SIEGE // ";font-size:9px;letter-spacing:2px;color:var(--accent);text-transform:uppercase;display:block;margin-bottom:4px;font-weight:700}
.chat-msg.assistant{border-left-color:var(--accent)}
.chat-msg.assistant::before{content:"SIEGE // ";font-size:9px;letter-spacing:2px;color:var(--accent);text-transform:uppercase;display:block;margin-bottom:4px;font-weight:700}
.chat-msg.sys{font-size:10px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;text-align:center;padding:4px 0;border:none}
.chat-msg p{margin-bottom:8px}
.chat-msg p:last-child{margin-bottom:0}
.chat-msg code{background:var(--bg);padding:1px 5px;border:1px solid var(--dim);font-size:12px;font-family:var(--mono)}
.chat-msg pre{background:var(--bg);padding:10px;border:1px solid var(--dim);overflow-x:auto;font-size:12px;margin:8px 0;font-family:var(--mono)}
.chat-msg ul,.chat-msg ol{margin-left:18px;margin-bottom:8px}
.chat-msg ul li,.chat-msg ol li{margin-bottom:4px}
.chat-msg strong{color:var(--accent)}
.chat-msg em{color:var(--sec)}
.chat-msg h3{font-family:var(--display);font-size:14px;color:var(--ink);margin:10px 0 6px;text-transform:lowercase;letter-spacing:1px}
.chat-msg a.pcode{color:var(--accent);border-bottom:1px dashed var(--accent);padding:0 2px;font-family:var(--term);font-size:14px}
.chat-msg a.pcode:hover{background:var(--accent);color:var(--bg)}

.chat-input-row{display:flex;border-top:2px solid var(--ink)}
.chat-input{flex:1;background:var(--bg);border:none;padding:14px 16px;color:var(--ink);font-family:var(--mono);font-size:13px;outline:none}
.chat-input:focus{background:var(--bg-2)}
.chat-send{background:var(--accent);border:none;color:var(--bg);padding:0 24px;font-family:var(--mono);font-weight:700;font-size:11px;letter-spacing:2px;cursor:pointer;border-left:2px solid var(--ink)}
.chat-send:hover{background:var(--ink)}
.chat-send:disabled{background:var(--dim);cursor:not-allowed}
.quick-prompts{display:flex;gap:6px;flex-wrap:wrap;margin-top:12px}
.quick-prompt{padding:6px 10px;border:1px solid var(--dim);background:var(--bg);color:var(--muted);font-size:10px;cursor:pointer;letter-spacing:1px;text-transform:uppercase;transition:all var(--tx);font-family:var(--mono)}
.quick-prompt:hover{border-color:var(--accent);color:var(--accent)}
.chat-empty{text-align:center;padding:60px 20px;color:var(--muted)}
.chat-empty .big{font-family:var(--display);font-size:24px;color:var(--ink);margin-bottom:8px;text-transform:lowercase}

.streaming-cursor{display:inline-block;width:8px;height:14px;background:var(--accent);margin-left:2px;animation:blink 1s steps(2) infinite;vertical-align:text-bottom}
@keyframes blink{50%{opacity:0}}

/* ============================================================
   POMODORO
   ============================================================ */
.pomo-wrap{border:2px solid var(--ink);padding:24px;background:var(--bg-2);text-align:center;position:relative}
.pomo-time{font-family:var(--term);font-size:96px;line-height:1;color:var(--accent);margin:14px 0}
.pomo-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:3px}
.pomo-mode{font-size:14px;color:var(--ink);text-transform:uppercase;letter-spacing:2px;margin-bottom:8px}
.pomo-ctrl{display:flex;gap:10px;justify-content:center;margin-top:16px;flex-wrap:wrap}
.pomo-subj{margin-top:16px;font-size:11px;color:var(--ink-dim);text-transform:uppercase;letter-spacing:1.5px}
.pomo-subj b{color:var(--accent)}

/* ============================================================
   STATS / CHARTS
   ============================================================ */
.chart-box{padding:16px;border:1px solid var(--dim);background:var(--bg);margin-top:12px}
.chart-box canvas{max-width:100%;display:block}
.heatmap{display:grid;grid-template-columns:repeat(52,1fr);gap:2px;margin-top:8px}
.heatmap-cell{aspect-ratio:1;background:var(--bg);border:1px solid var(--line);transition:all var(--tx);position:relative}
.heatmap-cell:hover{outline:1px solid var(--ink);z-index:2}
.heatmap-cell[data-lvl="0"]{background:var(--bg-2)}
.heatmap-cell[data-lvl="1"]{background:rgba(var(--accent-rgb),0.25)}
.heatmap-cell[data-lvl="2"]{background:rgba(var(--accent-rgb),0.5)}
.heatmap-cell[data-lvl="3"]{background:rgba(var(--accent-rgb),0.8)}
.heatmap-cell[data-lvl="4"]{background:var(--accent)}
.heatmap-legend{display:flex;align-items:center;gap:6px;justify-content:flex-end;margin-top:10px;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:1px}
.heatmap-legend .sq{width:10px;height:10px;border:1px solid var(--line)}

/* ============================================================
   NOTES VAULT
   ============================================================ */
.notes-grid{display:grid;grid-template-columns:240px 1fr;gap:16px;margin-top:16px;min-height:400px}
@media(max-width:800px){.notes-grid{grid-template-columns:1fr}}
.notes-side{border:1px solid var(--dim);background:var(--bg);padding:8px;overflow-y:auto;max-height:500px}
.notes-side .nitem{padding:8px 10px;cursor:pointer;font-size:11px;border-left:2px solid transparent;color:var(--ink-dim);transition:all var(--tx)}
.notes-side .nitem:hover{background:var(--bg-2);color:var(--ink)}
.notes-side .nitem.active{border-left-color:var(--accent);color:var(--ink);background:var(--bg-2)}
.notes-side .nitem .nt{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:2px}
.notes-edit{display:flex;flex-direction:column;gap:0;border:1px solid var(--dim)}
.notes-edit textarea{flex:1;min-height:400px;background:var(--bg);border:none;padding:14px;color:var(--ink);font-family:var(--mono);font-size:13px;outline:none;resize:none}
.notes-edit-foot{padding:8px 12px;border-top:1px solid var(--dim);display:flex;justify-content:space-between;align-items:center;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px}

/* ============================================================
   MISTAKE LOG
   ============================================================ */
.mistake-item{border:1px solid var(--line);padding:14px;margin-bottom:8px;background:var(--bg);position:relative}
.mistake-item .mi-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;gap:8px;flex-wrap:wrap}
.mistake-item .mi-q{font-size:13px;color:var(--ink);margin-bottom:6px;line-height:1.5}
.mistake-item .mi-exp{font-size:12px;color:var(--ink-dim);background:var(--bg-2);padding:10px;border-left:2px solid var(--sec);margin-top:8px}
.mistake-item .mi-meta{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1.5px;display:flex;gap:8px;flex-wrap:wrap;align-items:center}

/* ============================================================
   FLASHCARDS
   ============================================================ */
.fc-wrap{border:2px solid var(--ink);background:var(--bg-2);padding:30px;text-align:center;min-height:300px;display:flex;flex-direction:column;justify-content:center;cursor:pointer;position:relative}
.fc-side{font-size:10px;color:var(--muted);letter-spacing:3px;text-transform:uppercase;margin-bottom:12px}
.fc-content{font-size:18px;color:var(--ink);line-height:1.5;flex:1;display:flex;align-items:center;justify-content:center;padding:20px 0}
.fc-progress{font-size:10px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-top:12px}
.fc-ctrl{display:flex;gap:10px;justify-content:center;margin-top:14px;flex-wrap:wrap}

/* ============================================================
   TERMINAL OUTPUT
   ============================================================ */
.term-out{
  background:var(--bg);border:1px solid var(--dim);padding:14px;margin-top:12px;
  font-family:var(--term);font-size:16px;line-height:1.4;color:var(--ok);
  max-height:300px;overflow-y:auto;
}
.term-out .line{white-space:pre-wrap;word-break:break-word}
.term-out .line.warn{color:var(--warn)}
.term-out .line.hot{color:var(--accent)}
.term-out .line.dim{color:var(--muted)}
.term-out .line.ok{color:var(--ok)}

/* ============================================================
   MODAL
   ============================================================ */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:200;display:none;align-items:center;justify-content:center;padding:20px;animation:fadeIn 0.15s ease}
.modal-bg.show{display:flex}
.modal{background:var(--bg-2);border:2px solid var(--ink);padding:28px;max-width:520px;width:100%;position:relative;max-height:90vh;overflow-y:auto}
.modal.wide{max-width:760px}
.modal h3{font-family:var(--display);font-size:22px;margin-bottom:18px;text-transform:lowercase;padding-right:30px}
.modal-close{position:absolute;top:12px;right:12px;background:none;border:none;color:var(--ink);font-size:22px;cursor:pointer;width:30px;height:30px}
.modal-close:hover{color:var(--accent)}

/* ============================================================
   ONBOARDING WIZARD
   ============================================================ */
.wiz-bg{position:fixed;inset:0;background:var(--bg);z-index:300;display:none;flex-direction:column;overflow-y:auto}
.wiz-bg.show{display:flex}
.wiz-bg::before{content:"";position:fixed;inset:0;pointer-events:none;background:repeating-linear-gradient(0deg,rgba(255,255,255,0.02) 0,rgba(255,255,255,0.02) 1px,transparent 1px,transparent 3px);z-index:1}
.wiz-head{padding:24px 32px;border-bottom:2px solid var(--ink);display:flex;justify-content:space-between;align-items:center;position:relative;z-index:5}
.wiz-head .wh-brand{display:flex;align-items:center;gap:10px}
.wiz-head .wh-brand .sb-mark{width:36px;height:36px;font-size:16px}
.wiz-head .wh-step{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:2px}
.wiz-head .wh-step b{color:var(--accent)}
.wiz-prog{height:4px;background:var(--line);position:relative;z-index:5}
.wiz-prog-bar{height:100%;background:var(--accent);transition:width 0.3s}
.wiz-body{flex:1;display:flex;align-items:center;justify-content:center;padding:40px 24px;position:relative;z-index:5}
.wiz-card{max-width:680px;width:100%}
.wiz-card h1{font-family:var(--display);font-size:clamp(28px,5vw,46px);line-height:1.1;text-transform:lowercase;margin-bottom:14px}
.wiz-card .wiz-sub{font-size:13px;color:var(--ink-dim);margin-bottom:30px;line-height:1.6}
.wiz-foot{padding:20px 32px;border-top:2px solid var(--ink);display:flex;justify-content:space-between;align-items:center;position:relative;z-index:5}
@media(max-width:600px){.wiz-head,.wiz-foot,.wiz-body{padding-left:16px;padding-right:16px}}

.wiz-options{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px}
.wiz-opt{padding:18px;border:2px solid var(--line);background:var(--bg-2);cursor:pointer;transition:all var(--tx);text-align:left}
.wiz-opt:hover{border-color:var(--ink)}
.wiz-opt.on{border-color:var(--accent);background:rgba(var(--accent-rgb),0.06)}
.wiz-opt-title{font-size:13px;font-weight:700;color:var(--ink);margin-bottom:4px;text-transform:uppercase;letter-spacing:1px}
.wiz-opt-desc{font-size:11px;color:var(--muted);line-height:1.4}
.wiz-opt-code{font-family:var(--term);font-size:14px;color:var(--accent);margin-bottom:6px}

.wiz-subj-list{max-height:380px;overflow-y:auto;border:1px solid var(--dim);background:var(--bg)}
.wiz-subj-row{display:flex;align-items:center;gap:12px;padding:10px 14px;border-bottom:1px solid var(--line);cursor:pointer;transition:all var(--tx)}
.wiz-subj-row:hover{background:var(--bg-2)}
.wiz-subj-row.on{background:rgba(var(--accent-rgb),0.08)}
.wiz-subj-row .wsr-chk{width:18px;height:18px;border:2px solid var(--dim);flex-shrink:0;display:flex;align-items:center;justify-content:center}
.wiz-subj-row.on .wsr-chk{background:var(--accent);border-color:var(--accent);color:var(--bg)}
.wiz-subj-row.on .wsr-chk::after{content:"✓"}
.wiz-subj-row .wsr-code{font-family:var(--term);font-size:14px;color:var(--accent);width:60px}
.wiz-subj-row .wsr-name{flex:1;font-size:12px;color:var(--ink)}
.wiz-subj-row .wsr-board{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px}

.wiz-strength{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-top:6px}
.wiz-strength button{padding:6px;background:var(--bg);border:1px solid var(--dim);color:var(--muted);font-family:var(--mono);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;transition:all var(--tx)}
.wiz-strength button:hover{color:var(--ink)}
.wiz-strength button.on{background:var(--accent);border-color:var(--accent);color:var(--bg)}

.wiz-search{margin-bottom:10px}
.wiz-search input{width:100%;background:var(--bg);border:1px solid var(--dim);padding:8px 12px;color:var(--ink);font-family:var(--mono);font-size:12px;outline:none}
.wiz-search input:focus{border-color:var(--accent)}

.wiz-strap{padding:16px;border:1px solid var(--accent);background:rgba(var(--accent-rgb),0.05);margin-bottom:24px;font-size:12px;color:var(--ink-dim);line-height:1.6}
.wiz-strap b{color:var(--accent);text-transform:uppercase;letter-spacing:1.5px;font-size:11px;display:block;margin-bottom:4px}

/* ============================================================
   COMMAND PALETTE
   ============================================================ */
.cmd-bg{position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:400;display:none;align-items:flex-start;justify-content:center;padding-top:100px}
.cmd-bg.show{display:flex}
.cmd{width:560px;max-width:90vw;background:var(--bg-2);border:2px solid var(--accent)}
.cmd input{width:100%;background:var(--bg);border:none;border-bottom:1px solid var(--dim);padding:16px 18px;color:var(--ink);font-family:var(--mono);font-size:14px;outline:none}
.cmd-results{max-height:400px;overflow-y:auto}
.cmd-result{padding:10px 18px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--line);transition:all var(--tx)}
.cmd-result:hover,.cmd-result.sel{background:var(--bg);color:var(--accent)}
.cmd-result-l{font-size:12px;color:var(--ink-dim)}
.cmd-result:hover .cmd-result-l,.cmd-result.sel .cmd-result-l{color:var(--accent)}
.cmd-result-r{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:1.5px}
.cmd-empty{padding:20px;text-align:center;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:1.5px}

/* ============================================================
   UTILITY
   ============================================================ */
.muted{color:var(--muted)}
.dim{color:var(--ink-dim)}
.row{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.row-between{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
.spacer{height:24px}
.spacer-sm{height:12px}
.divider{height:2px;background:var(--ink);margin:24px 0}
.divider-thin{height:1px;background:var(--line);margin:16px 0}
.hidden{display:none !important}
.no-margin{margin:0}
.center{text-align:center}
.mono-h{font-family:var(--display);text-transform:lowercase;letter-spacing:1px}
.term-num{font-family:var(--term);color:var(--accent)}

/* toast */
.toast{position:fixed;bottom:24px;right:24px;background:var(--ink);color:var(--bg);padding:14px 18px;font-size:11px;letter-spacing:2px;text-transform:uppercase;border:2px solid var(--accent);z-index:500;transform:translateX(120%);transition:transform 0.3s;font-weight:700;max-width:320px}
.toast.show{transform:none}
.toast.bad{border-color:var(--bad);background:var(--bad);color:var(--bg)}

/* loading spinner */
.spinner{display:inline-block;width:14px;height:14px;border:2px solid var(--dim);border-top-color:var(--accent);animation:spin 0.8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* empty state */
.empty{padding:40px 20px;text-align:center;color:var(--muted)}
.empty .big{font-family:var(--display);font-size:24px;color:var(--ink);margin-bottom:8px;text-transform:lowercase}
.empty .sm{font-size:12px;margin-bottom:14px;line-height:1.6}

/* badge */
.badge-noai{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border:1px solid var(--accent);color:var(--accent);font-size:10px;text-transform:uppercase;letter-spacing:1.5px;background:rgba(var(--accent-rgb),0.04);font-weight:700}
.badge-noai::before{content:"●";color:var(--accent)}

/* ============================================================
   PRINT
   ============================================================ */
@media print{
  body{background:#fff;color:#000}
  body::before,body::after{display:none}
  .sidebar,.mobile-nav-btn,.sb-foot,nav,.btn,.chat-input-row,.modal-bg,.cmd-bg,.toast,.wiz-bg{display:none !important}
  .app{grid-template-columns:1fr}
  .main{padding:20px}
  .card,.hero{border:1px solid #000;background:#fff;color:#000}
  .hero h1,.section-head h2{color:#000}
  .pill{border-color:#000;color:#000;background:#fff}
  .mission-item{border-color:#000;background:#fff}
  .mission-task{color:#000}
  .print-only{display:block !important}
  .print-page-break{page-break-after:always}
  .stat-big,.subj-pct,.countdown-val{color:#000}
}
.print-only{display:none}

/* ============================================================
   RTL (Arabic)
   ============================================================ */
[dir="rtl"] .sb-item{border-left:none;border-right:3px solid transparent;text-align:right}
[dir="rtl"] .sb-item.active{border-right-color:var(--accent)}
[dir="rtl"] .chat-msg{border-left:none;border-right:2px solid var(--sec);padding-left:0;padding-right:16px}
[dir="rtl"] .chat-msg.ai,[dir="rtl"] .chat-msg.assistant{border-right-color:var(--accent)}
[dir="rtl"] .hero::before,[dir="rtl"] .card-tag{left:auto;right:16px}
</style>
</head>
<body data-theme="red">

<button class="mobile-nav-btn" id="mobile-nav-btn">≡</button>
<div class="sidebar-backdrop" id="sb-backdrop"></div>

<div class="app">

<!-- ============================================================
     SIDEBAR
     ============================================================ -->
<aside class="sidebar" id="sidebar">
  <div class="sb-brand">
    <div class="sb-mark">S</div>
    <div>
      <div class="sb-name">siege</div>
      <div class="sb-sub">study terminal</div>
    </div>
  </div>

  <div class="sb-profile" id="sb-profile" title="switch profile">
    <div class="sb-avatar" id="sb-avatar">?</div>
    <div class="sb-pn">
      <div class="sb-pn-name" id="sb-pn-name">no profile</div>
      <div class="sb-pn-meta" id="sb-pn-meta">tap to switch</div>
    </div>
    <div class="sb-pn-icon">▾</div>
  </div>

  <nav class="sb-nav" id="sb-nav">
    <button class="sb-item active" data-tab="dash"><span class="sb-icon">▤</span><span>dashboard</span></button>
    <button class="sb-item" data-tab="subj"><span class="sb-icon">≡</span><span>subjects</span></button>
    <button class="sb-item" data-tab="papers"><span class="sb-icon">⊟</span><span>past papers</span></button>
    <button class="sb-item" data-tab="ai"><span class="sb-icon">◆</span><span>siege.ai</span></button>
    <button class="sb-item" data-tab="pomo"><span class="sb-icon">◉</span><span>pomodoro</span></button>
    <button class="sb-item" data-tab="stats"><span class="sb-icon">▦</span><span>stats</span></button>
    <button class="sb-item" data-tab="mistakes"><span class="sb-icon">✕</span><span>mistakes</span></button>
    <button class="sb-item" data-tab="notes"><span class="sb-icon">▢</span><span>notes</span></button>
    <button class="sb-item" data-tab="flash"><span class="sb-icon">◇</span><span>flashcards</span></button>
    <button class="sb-item" data-tab="cfg"><span class="sb-icon">⚙</span><span>settings</span></button>
    <button class="sb-item" data-tab="help"><span class="sb-icon">?</span><span>help</span></button>
  </nav>

  <div class="sb-foot">
    <div class="row"><span><span class="dot" id="sb-ai-dot"></span>siege.ai</span><b id="sb-ai-state">offline</b></div>
    <div class="row"><span>streak</span><b id="sb-streak">0d</b></div>
    <div class="row"><span>v1.0.0</span><b>⌘K</b></div>
  </div>
</aside>

<!-- ============================================================
     MAIN
     ============================================================ -->
<main class="main">

<!-- =========================================================
     DASHBOARD
     ========================================================= -->
<section class="section active" id="sec-dash">
  <div class="hero">
    <h1 id="hero-title">good morning,student</h1>
    <div class="hero-meta">
      <span>day <b id="hero-day">--</b> of <b id="hero-total">--</b></span>
      <span class="acc">deadline <b id="hero-deadline">--</b></span>
      <span>exam in <b id="hero-exam">--</b> days</span>
      <span><span class="badge-noai">real past papers · no ai hallucinations</span></span>
    </div>
    <div class="row">
      <button class="btn hot" id="gen-mission">[ generate today's mission ]</button>
      <button class="btn ghost" id="show-progress">progress.log</button>
      <button class="btn ghost" onclick="go('ai')">open ai →</button>
      <button class="btn ghost" onclick="window.print()">print weekly plan</button>
    </div>
    <div id="mission-zone" class="mission-list"></div>
    <div id="term-zone"></div>
  </div>

  <div class="grid-4">
    <div class="card">
      <span class="card-tag hot">// papers</span>
      <div class="stat-big" id="stat-papers">0</div>
      <div class="stat-label">papers logged</div>
    </div>
    <div class="card">
      <span class="card-tag cy">// streak</span>
      <div class="stat-big" id="stat-streak">0</div>
      <div class="stat-label">day streak</div>
      <div class="stat-sub" id="stat-streak-sub" style="font-size:10px;color:var(--muted)">freeze available</div>
    </div>
    <div class="card">
      <span class="card-tag warn">// topics</span>
      <div class="stat-big" id="stat-topics">0</div>
      <div class="stat-label">topics mastered</div>
    </div>
    <div class="card">
      <span class="card-tag">// days left</span>
      <div class="stat-big" id="stat-days">--</div>
      <div class="stat-label">till deadline</div>
    </div>
  </div>

  <div class="card">
    <span class="card-tag">// syllabus coverage</span>
    <div id="dash-bars" style="margin-top:8px"></div>
  </div>

  <div class="spacer"></div>

  <div class="grid-2">
    <div class="card">
      <span class="card-tag cy">// weak areas (this week)</span>
      <div id="dash-weak" style="margin-top:10px"></div>
    </div>
    <div class="card">
      <span class="card-tag warn">// up next (srs)</span>
      <div id="dash-srs" style="margin-top:10px"></div>
    </div>
  </div>
</section>

<!-- =========================================================
     SUBJECTS
     ========================================================= -->
<section class="section" id="sec-subj">
  <div class="section-head">
    <h2>subjects</h2>
    <div class="meta" id="subj-count">0 enrolled</div>
  </div>
  <div class="row" style="margin-bottom:16px">
    <select id="subj-picker" style="background:var(--bg);border:2px solid var(--ink);color:var(--ink);padding:8px 12px;font-family:var(--mono);font-size:12px;flex:1;max-width:400px"></select>
    <button class="btn ghost" id="subj-add">+ add subject</button>
    <button class="btn ghost" id="subj-remove">remove from profile</button>
  </div>
  <div id="subj-content"></div>
</section>

<!-- =========================================================
     PAPERS
     ========================================================= -->
<section class="section" id="sec-papers">
  <div class="section-head">
    <h2>past papers</h2>
    <div class="meta"><span class="badge-noai">real codes · external links</span></div>
  </div>

  <div class="paper-filters">
    <span class="filt-lbl">subject</span>
    <select id="pf-subj"></select>
    <span class="filt-lbl">paper</span>
    <select id="pf-paper"></select>
    <span class="filt-lbl">year</span>
    <select id="pf-year">
      <option value="all">all</option>
    </select>
    <span class="filt-lbl">session</span>
    <select id="pf-session">
      <option value="all">all</option>
      <option value="M/J">M/J</option>
      <option value="O/N">O/N</option>
      <option value="F/M">F/M</option>
    </select>
    <span class="filt-lbl">status</span>
    <select id="pf-status">
      <option value="all">all</option>
      <option value="todo">not started</option>
      <option value="attempted">attempted</option>
      <option value="done">done</option>
    </select>
    <button class="btn xs ghost" id="pf-reset">reset</button>
  </div>

  <div id="papers-grid" class="paper-grid"></div>

  <div class="spacer"></div>

  <div class="card">
    <span class="card-tag hot">// real past paper sources</span>
    <p style="margin-top:8px;font-size:12px;color:var(--ink-dim)">External links open in a new tab. SIEGE does not host or redistribute past papers — it indexes the real CAIE/Edexcel paper codes and links to public mirrors.</p>
    <div class="row" style="margin-top:12px">
      <a href="https://papers.gceguide.com" target="_blank" class="btn ghost sm">gceguide.com →</a>
      <a href="https://papacambridge.com" target="_blank" class="btn ghost sm">papacambridge.com →</a>
      <a href="https://www.savemyexams.com" target="_blank" class="btn ghost sm">savemyexams.com →</a>
      <a href="https://www.physicsandmathstutor.com" target="_blank" class="btn ghost sm">physicsandmathstutor →</a>
    </div>
  </div>
</section>

<!-- =========================================================
     AI
     ========================================================= -->
<section class="section" id="sec-ai">
  <div class="section-head">
    <h2>siege.ai</h2>
    <div class="meta" id="ai-status">groq · standby</div>
  </div>

  <div class="wiz-strap">
    <b>// the rules</b>
    SIEGE does not invent past paper questions or fake paper codes. The AI's job is to find real past papers, explain questions you don't understand, walk through mark schemes, and plan your study. Always verify references against the linked sources.
  </div>

  <div class="ai-modes" id="ai-modes">
    <div class="mode-card active" data-mode="plan">
      <div class="mode-icon">▤</div>
      <div class="mode-name">plan</div>
      <div class="mode-desc">daily mission with real paper codes</div>
    </div>
    <div class="mode-card" data-mode="explain">
      <div class="mode-icon">?</div>
      <div class="mode-name">explain</div>
      <div class="mode-desc">paste a question, get a breakdown</div>
    </div>
    <div class="mode-card" data-mode="markscheme">
      <div class="mode-icon">⊟</div>
      <div class="mode-name">mark scheme</div>
      <div class="mode-desc">grade your answer like CAIE would</div>
    </div>
    <div class="mode-card" data-mode="weakness">
      <div class="mode-icon">!</div>
      <div class="mode-name">weakness audit</div>
      <div class="mode-desc">find what to fix next</div>
    </div>
    <div class="mode-card" data-mode="recommender">
      <div class="mode-icon">▸</div>
      <div class="mode-name">recommender</div>
      <div class="mode-desc">which paper should i attempt?</div>
    </div>
    <div class="mode-card" data-mode="concept">
      <div class="mode-icon">◆</div>
      <div class="mode-name">concept tutor</div>
      <div class="mode-desc">explain a syllabus topic</div>
    </div>
    <div class="mode-card" data-mode="command">
      <div class="mode-icon">⊳</div>
      <div class="mode-name">command words</div>
      <div class="mode-desc">drill describe/explain/justify</div>
    </div>
    <div class="mode-card" data-mode="socratic">
      <div class="mode-icon">∴</div>
      <div class="mode-name">socratic</div>
      <div class="mode-desc">ai asks, you answer</div>
    </div>
  </div>

  <div class="chat-box">
    <div class="chat-head">
      <div class="chat-head-title" id="chat-mode-label">// plan mode</div>
      <div class="chat-head-status off" id="chat-status"><span class="dot"></span><span>standby</span></div>
    </div>
    <div class="chat-log" id="chat-log"></div>
    <div class="chat-input-row">
      <input class="chat-input" id="chat-input" placeholder="ask siege..." autocomplete="off">
      <button class="chat-send" id="chat-send">SEND</button>
    </div>
  </div>
  <div class="quick-prompts" id="quick-prompts"></div>
</section>

<!-- =========================================================
     POMODORO
     ========================================================= -->
<section class="section" id="sec-pomo">
  <div class="section-head">
    <h2>pomodoro</h2>
    <div class="meta">focus timer · logs to subject</div>
  </div>

  <div class="grid-2">
    <div class="pomo-wrap">
      <div class="pomo-label">timer</div>
      <div class="pomo-mode" id="pomo-mode">focus</div>
      <div class="pomo-time" id="pomo-time">25:00</div>
      <div class="pomo-ctrl">
        <button class="btn hot" id="pomo-start">[ start ]</button>
        <button class="btn ghost" id="pomo-pause" disabled>pause</button>
        <button class="btn ghost" id="pomo-reset">reset</button>
      </div>
      <div class="pomo-subj">subject: <b id="pomo-subj-label">—</b></div>
    </div>

    <div class="card">
      <span class="card-tag">// session config</span>
      <div class="field" style="margin-top:10px">
        <label>subject</label>
        <select id="pomo-subj"></select>
      </div>
      <div class="field-row">
        <div class="field"><label>focus (min)</label><input type="number" id="pomo-focus" value="25" min="5" max="120"></div>
        <div class="field"><label>break (min)</label><input type="number" id="pomo-break" value="5" min="1" max="30"></div>
      </div>
      <button class="btn ghost full" id="pomo-cfg-save">save</button>
    </div>
  </div>

  <div class="spacer"></div>

  <div class="card">
    <span class="card-tag">// today's logged time</span>
    <div id="pomo-log" style="margin-top:10px"></div>
  </div>
</section>

<!-- =========================================================
     STATS
     ========================================================= -->
<section class="section" id="sec-stats">
  <div class="section-head">
    <h2>stats</h2>
    <div class="meta" id="stats-meta">all-time</div>
  </div>

  <div class="grid-2">
    <div class="card">
      <span class="card-tag hot">// weekly study time</span>
      <div class="chart-box"><canvas id="chart-time" width="600" height="220"></canvas></div>
    </div>
    <div class="card">
      <span class="card-tag cy">// score trend</span>
      <div class="chart-box"><canvas id="chart-scores" width="600" height="220"></canvas></div>
    </div>
  </div>

  <div class="spacer"></div>

  <div class="card">
    <span class="card-tag warn">// streak calendar (last 52 weeks)</span>
    <div id="heatmap" class="heatmap"></div>
    <div class="heatmap-legend"><span>less</span><span class="sq" data-lvl="0"></span><span class="sq" data-lvl="1"></span><span class="sq" data-lvl="2"></span><span class="sq" data-lvl="3"></span><span class="sq" data-lvl="4"></span><span>more</span></div>
  </div>

  <div class="spacer"></div>

  <div class="card">
    <span class="card-tag">// topic mastery heatmap (per subject)</span>
    <div id="mastery-map" style="margin-top:14px"></div>
  </div>
</section>

<!-- =========================================================
     MISTAKES
     ========================================================= -->
<section class="section" id="sec-mistakes">
  <div class="section-head">
    <h2>mistake log</h2>
    <div class="meta">questions you got wrong</div>
  </div>
  <div class="row" style="margin-bottom:14px">
    <button class="btn hot" id="mistake-add">+ log a mistake</button>
    <select id="mistake-filter" style="background:var(--bg);border:1px solid var(--dim);color:var(--ink);padding:6px;font-family:var(--mono);font-size:11px"><option value="all">all subjects</option></select>
  </div>
  <div id="mistakes-list"></div>
</section>

<!-- =========================================================
     NOTES
     ========================================================= -->
<section class="section" id="sec-notes">
  <div class="section-head">
    <h2>notes vault</h2>
    <div class="meta">markdown · per topic</div>
  </div>
  <div class="row" style="margin-bottom:10px">
    <select id="notes-subj" style="background:var(--bg);border:1px solid var(--dim);color:var(--ink);padding:6px;font-family:var(--mono);font-size:11px"></select>
  </div>
  <div class="notes-grid">
    <div class="notes-side" id="notes-side"></div>
    <div class="notes-edit">
      <textarea id="notes-edit" placeholder="select a topic on the left to start taking notes..."></textarea>
      <div class="notes-edit-foot">
        <span id="notes-status">no topic selected</span>
        <span class="muted">auto-saved</span>
      </div>
    </div>
  </div>
</section>

<!-- =========================================================
     FLASHCARDS
     ========================================================= -->
<section class="section" id="sec-flash">
  <div class="section-head">
    <h2>flashcards</h2>
    <div class="meta">manual · spaced review</div>
  </div>
  <div class="row" style="margin-bottom:14px">
    <select id="flash-subj" style="background:var(--bg);border:1px solid var(--dim);color:var(--ink);padding:6px;font-family:var(--mono);font-size:11px"></select>
    <button class="btn ghost" id="flash-add">+ new card</button>
    <button class="btn ghost" id="flash-review">review queue</button>
    <button class="btn ghost" id="flash-all">browse all</button>
  </div>
  <div id="flash-content"></div>
</section>

<!-- =========================================================
     SETTINGS
     ========================================================= -->
<section class="section" id="sec-cfg">
  <div class="section-head">
    <h2>settings</h2>
    <div class="meta">profile · ai · data</div>
  </div>

  <div class="grid-2">
    <div class="card">
      <span class="card-tag hot">// groq api</span>
      <div class="field" style="margin-top:10px">
        <label>api key</label>
        <input type="password" id="cfg-key" placeholder="gsk_...">
        <div class="field-hint">stored locally only. get one free at <a href="https://console.groq.com/keys" target="_blank">console.groq.com/keys</a></div>
      </div>
      <div class="field">
        <label>model</label>
        <select id="cfg-model">
          <option value="openai/gpt-oss-120b" selected>gpt-oss-120b (strongest)</option>
          <option value="llama-3.3-70b-versatile">llama-3.3-70b-versatile (balanced)</option>
          <option value="llama-3.1-8b-instant">llama-3.1-8b-instant (fastest)</option>
          <option value="qwen/qwen3-32b">qwen3-32b</option>
          <option value="meta-llama/llama-4-scout-17b-16e-instruct">llama-4-scout (preview)</option>
        </select>
      </div>
      <button class="btn hot" id="cfg-save">save & test</button>
    </div>

    <div class="card">
      <span class="card-tag">// schedule</span>
      <div class="field" style="margin-top:10px">
        <label>finish-by deadline</label>
        <input type="date" id="cfg-deadline">
      </div>
      <div class="field">
        <label>exam date</label>
        <input type="date" id="cfg-exam">
      </div>
      <div class="field">
        <label>daily study budget (hours)</label>
        <input type="number" id="cfg-hours" min="1" max="12" step="0.5" value="4">
      </div>
      <button class="btn" id="cfg-save-sched">save</button>
    </div>
  </div>

  <div class="spacer"></div>

  <div class="grid-2">
    <div class="card">
      <span class="card-tag cy">// profile</span>
      <div class="field" style="margin-top:10px">
        <label>name</label>
        <input type="text" id="cfg-name" placeholder="operator">
      </div>
      <div class="field">
        <label>avatar (1 char)</label>
        <input type="text" id="cfg-avatar" maxlength="2">
      </div>
      <div class="row">
        <button class="btn" id="cfg-profile-save">save</button>
        <button class="btn ghost" id="cfg-profile-new">+ new profile</button>
        <button class="btn danger" id="cfg-profile-del">delete profile</button>
      </div>
    </div>

    <div class="card">
      <span class="card-tag">// appearance</span>
      <div class="field" style="margin-top:10px">
        <label>theme</label>
        <div class="seg" id="theme-seg">
          <button data-theme="red" class="on">brutalist red</button>
          <button data-theme="green">terminal green</button>
          <button data-theme="mono">mono white</button>
        </div>
      </div>
      <div class="field">
        <label>direction</label>
        <div class="seg" id="dir-seg">
          <button data-dir="ltr" class="on">ltr (english)</button>
          <button data-dir="rtl">rtl (arabic)</button>
        </div>
      </div>
    </div>
  </div>

  <div class="spacer"></div>

  <div class="grid-2">
    <div class="card">
      <span class="card-tag warn">// license</span>
      <div class="field" style="margin-top:10px">
        <label>license key</label>
        <input type="text" id="cfg-license" placeholder="enter key from gumroad">
        <div class="field-hint" id="cfg-license-status">unlicensed (offline mode unrestricted)</div>
      </div>
      <button class="btn ghost" id="cfg-license-save">apply</button>
    </div>

    <div class="card">
      <span class="card-tag">// data</span>
      <p style="font-size:11px;color:var(--ink-dim);margin-top:6px;margin-bottom:14px">export your data as encrypted JSON (password-protected) or plain JSON.</p>
      <div class="row">
        <button class="btn ghost" id="data-export">export (plain)</button>
        <button class="btn ghost" id="data-export-enc">export (encrypted)</button>
        <button class="btn ghost" id="data-import">import</button>
        <input type="file" id="data-file" accept=".json" style="display:none">
        <button class="btn danger" id="data-clear">wipe profile</button>
      </div>
    </div>
  </div>

  <div class="spacer"></div>

  <div class="card">
    <span class="card-tag">// system prompt (advanced)</span>
    <p style="font-size:11px;color:var(--ink-dim);margin-top:6px;margin-bottom:8px">Custom instructions appended to siege.ai's system prompt for this profile. Leave blank for default.</p>
    <div class="field">
      <textarea id="cfg-sysprompt" placeholder="e.g. always reply in casual lowercase. focus extra hard on chem stoichiometry."></textarea>
    </div>
    <button class="btn" id="cfg-sysprompt-save">save</button>
  </div>
</section>

<!-- =========================================================
     HELP
     ========================================================= -->
<section class="section" id="sec-help">
  <div class="section-head">
    <h2>help</h2>
    <div class="meta">docs · faq · shortcuts</div>
  </div>

  <div class="grid-2">
    <div class="card">
      <h3>quick start</h3>
      <ol style="margin-left:18px;font-size:12px;color:var(--ink-dim);line-height:1.8">
        <li>open settings → paste your groq api key (free at console.groq.com/keys)</li>
        <li>go to subjects → enable the syllabus topics you've covered</li>
        <li>go to dashboard → hit [generate today's mission]</li>
        <li>open past papers → attempt the recommended paper using the gceguide link</li>
        <li>log your score & wrong questions → siege ai builds your weakness map</li>
      </ol>
    </div>

    <div class="card">
      <h3>keyboard shortcuts</h3>
      <table style="width:100%;font-size:12px;color:var(--ink-dim)">
        <tr><td><code>⌘K</code> / <code>Ctrl+K</code></td><td>command palette</td></tr>
        <tr><td><code>g d</code></td><td>dashboard</td></tr>
        <tr><td><code>g a</code></td><td>ai</td></tr>
        <tr><td><code>g p</code></td><td>papers</td></tr>
        <tr><td><code>g s</code></td><td>stats</td></tr>
        <tr><td><code>g f</code></td><td>flashcards</td></tr>
        <tr><td><code>g n</code></td><td>notes</td></tr>
        <tr><td><code>n m</code></td><td>new mission</td></tr>
        <tr><td><code>?</code></td><td>help</td></tr>
        <tr><td><code>Esc</code></td><td>close modal</td></tr>
      </table>
    </div>
  </div>

  <div class="spacer"></div>

  <div class="card">
    <h3>frequently asked</h3>
    <p><b style="color:var(--accent)">Does SIEGE generate practice questions with AI?</b><br>
    No. This is the core principle. AI-generated questions are unreliable and don't match real CAIE mark schemes. SIEGE only references real past papers (with real paper codes like <code>0620/42/O/N/22</code>) and links to public mirrors like gceguide.com.</p>
    <div class="divider-thin"></div>
    <p><b style="color:var(--accent)">Where is my data stored?</b><br>
    Entirely in your browser's localStorage. Nothing is sent to any server except your Groq API calls (which only contain the chat messages you send). You can export everything as JSON, encrypted or plain.</p>
    <div class="divider-thin"></div>
    <p><b style="color:var(--accent)">Can I add subjects not in the catalog?</b><br>
    Yes — see CUSTOMIZATION.md. The syllabus is editable JSON in the source. Add your own topics, paper structure, and codes.</p>
    <div class="divider-thin"></div>
    <p><b style="color:var(--accent)">Why brutalist?</b><br>
    Because every other study app looks the same. SIEGE makes opening it feel different — like a command terminal, not another Notion clone. The aesthetic is part of the discipline.</p>
    <div class="divider-thin"></div>
    <p><b style="color:var(--accent)">Which Groq model should I use?</b><br>
    Default <code>gpt-oss-120b</code> is best for reasoning (explanations, mark scheme grading). Switch to <code>llama-3.1-8b-instant</code> if you want sub-second responses for the daily plan.</p>
    <div class="divider-thin"></div>
    <p><b style="color:var(--accent)">Does it work offline?</b><br>
    Mostly. Mission generation has a rule-based fallback. AI chat needs internet + Groq key. Everything else (topics, papers, notes, pomodoro, stats) works offline.</p>
  </div>

  <div class="spacer"></div>

  <div class="card">
    <h3>past paper sources</h3>
    <p>SIEGE indexes paper codes and provides external links. We do not host the papers. Use any of these mirrors:</p>
    <ul style="margin-left:20px;font-size:12px;line-height:1.8">
      <li><a href="https://papers.gceguide.com" target="_blank">gceguide.com</a> — primary, most reliable for CAIE</li>
      <li><a href="https://papacambridge.com" target="_blank">papacambridge.com</a> — alternative CAIE mirror</li>
      <li><a href="https://www.savemyexams.com" target="_blank">savemyexams.com</a> — by-question + topic questions</li>
      <li><a href="https://www.physicsandmathstutor.com" target="_blank">physicsandmathstutor.com</a> — better for Edexcel</li>
    </ul>
  </div>
</section>

</main>
</div>

<!-- modal -->
<div class="modal-bg" id="modal-bg">
  <div class="modal" id="modal">
    <button class="modal-close" id="modal-close">✕</button>
    <div id="modal-body"></div>
  </div>
</div>

<!-- command palette -->
<div class="cmd-bg" id="cmd-bg">
  <div class="cmd">
    <input id="cmd-input" placeholder="type a command... (jump to dashboard, generate mission, log paper, etc)">
    <div class="cmd-results" id="cmd-results"></div>
  </div>
</div>

<!-- toast -->
<div class="toast" id="toast"></div>

<!-- ============================================================
     ONBOARDING WIZARD
     ============================================================ -->
<div class="wiz-bg" id="wiz-bg">
  <div class="wiz-head">
    <div class="wh-brand">
      <div class="sb-mark">S</div>
      <div>
        <div class="sb-name">siege</div>
        <div class="sb-sub">study terminal · setup</div>
      </div>
    </div>
    <div class="wh-step">step <b id="wiz-step">1</b> / 8</div>
  </div>
  <div class="wiz-prog"><div class="wiz-prog-bar" id="wiz-prog-bar" style="width:12.5%"></div></div>
  <div class="wiz-body">
    <div class="wiz-card" id="wiz-card"></div>
  </div>
  <div class="wiz-foot">
    <button class="btn ghost" id="wiz-back">← back</button>
    <div class="row">
      <button class="btn ghost" id="wiz-skip">skip</button>
      <button class="btn hot" id="wiz-next">next →</button>
    </div>
  </div>
</div>

